<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background"
        android:orientation="horizontal"
        android:padding="12dp">

    <!-- Left Column: Controls & Status -->
    <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:orientation="vertical">

        <!-- Top: Capture Button -->
        <LinearLayout
                android:id="@+id/btn_app"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/btn_capture_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <ImageView
                    android:id="@+id/ic_camera"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_camera" />

            <TextView
                    android:id="@+id/app_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/app_name"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
        </LinearLayout>

        <!-- Middle: Secondary Buttons -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

            <FrameLayout
                    android:id="@+id/btn_filters"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_secondary_bg"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:id="@+id/ic_filters"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/auto_awesome"
                        android:tint="@color/widget_text_primary" />
            </FrameLayout>

            <FrameLayout
                    android:id="@+id/btn_frames"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_secondary_bg"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:id="@+id/ic_frames"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/border_bottom"
                        android:tint="@color/widget_text_primary" />
            </FrameLayout>

            <FrameLayout
                    android:id="@+id/btn_phantom"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_secondary_bg"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:id="@+id/phantom_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ghost_solid"
                        android:tint="@color/widget_accent" />

                <ImageView
                        android:id="@+id/phantom_icon_off"
                        android:visibility="gone"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ghost_solid"
                        android:alpha="0.5"
                        android:tint="@color/widget_text_primary" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Right Column: Recent Photos -->
    <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

        <LinearLayout
                android:id="@+id/btn_recent_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

            <TextView
                    android:id="@+id/recent_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            <ImageView
                    android:id="@+id/recent_arrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:tint="@color/widget_recent_accent" />
        </LinearLayout>

        <ImageView
                android:id="@+id/photo_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="4dp"
                android:layout_weight="1"
                android:clipToOutline="true"
                android:background="@drawable/btn_secondary_bg"
                android:scaleType="centerCrop" />

    </LinearLayout>

</LinearLayout>


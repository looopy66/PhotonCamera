{
    "id": "minimal_black",
    "name": "极简黑框",
    "version": 1,
    "layout": {
        "position": "BOTTOM",
        "height": 60,
        "backgroundColor": "#1A1A1A",
        "padding": 20
    },
    "elements": [
        {
            "type": "text",
            "textType": "DEVICE_MODEL",
            "alignment": "START",
            "fontSize": 14,
            "color": "#FFFFFF",
            "fontWeight": "MEDIUM"
        },
        {
            "type": "text",
            "textType": "DATE",
            "alignment": "END",
            "fontSize": 12,
            "color": "#AAAAAA",
            "format": "yyyy/MM/dd"
        }
    ]
}
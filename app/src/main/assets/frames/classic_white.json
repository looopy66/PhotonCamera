{
  "id": "classic_white",
  "name": "经典白框",
  "version": 1,
  "layout": {
    "position": "BOTTOM",
    "height": 80,
    "backgroundColor": "#FFFFFF",
    "padding": 20
  },
  "elements": [
    {
      "type": "text",
      "textType": "BRAND",
      "alignment": "START",
      "fontSize": 16,
      "color": "#000000",
      "fontWeight": "BOLD",
      "line": 0
    },
    {
      "type": "text",
      "textType": "DEVICE_MODEL",
      "alignment": "START",
      "fontSize": 16,
      "color": "#000000",
      "fontWeight": "BOLD",
      "line": 0
    },
    {
      "type": "text",
      "textType": "DATETIME",
      "alignment": "START",
      "fontSize": 12,
      "color": "#999999",
      "format": "yyyy.MM.dd HH:mm:ss",
      "line": 1
    },
    {
      "type": "logo",
      "logoType": "APP",
      "alignment": "END",
      "size": 32,
      "line": -1
    },
    {
      "type": "divider",
      "orientation": "VERTICAL",
      "alignment": "END",
      "length": 36,
      "thickness": 1,
      "color": "#E0E0E0",
      "margin": 8,
      "line": -1
    },
    {
      "type": "text",
      "textType": "FOCAL_LENGTH_35MM",
      "alignment": "END",
      "fontSize": 16,
      "color": "#000000",
      "fontWeight": "BOLD",
      "line": -1
    },
    {
      "type": "text",
      "textType": "SHUTTER_SPEED",
      "alignment": "END",
      "fontSize": 16,
      "color": "#000000",
      "fontWeight": "BOLD",
      "line": -1
    },
    {
      "type": "text",
      "textType": "ISO",
      "alignment": "END",
      "fontSize": 16,
      "color": "#000000",
      "fontWeight": "BOLD",
      "line": -1
    }
  ]
}
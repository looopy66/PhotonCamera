{
    "id": "pro_camera",
    "name": "专业相机",
    "version": 1,
    "layout": {
        "position": "BOTTOM",
        "height": 72,
        "backgroundColor": "#0D0D0D",
        "padding": 16
    },
    "elements": [
        {
            "type": "logo",
            "logoType": "BRAND",
            "alignment": "START",
            "size": 20,
            "tint": "#FF6600"
        },
        {
            "type": "text",
            "textType": "BRAND",
            "alignment": "START",
            "fontSize": 14,
            "color": "#FF6600",
            "fontWeight": "BOLD"
        },
        {
            "type": "divider",
            "orientation": "VERTICAL",
            "alignment": "START",
            "length": 20,
            "thickness": 2,
            "color": "#FF6600",
            "margin": 10
        },
        {
            "type": "text",
            "textType": "FOCAL_LENGTH",
            "alignment": "START",
            "fontSize": 11,
            "color": "#CCCCCC"
        },
        {
            "type": "text",
            "textType": "APERTURE",
            "alignment": "START",
            "fontSize": 11,
            "color": "#CCCCCC"
        },
        {
            "type": "text",
            "textType": "SHUTTER_SPEED",
            "alignment": "START",
            "fontSize": 11,
            "color": "#CCCCCC"
        },
        {
            "type": "text",
            "textType": "ISO",
            "alignment": "START",
            "fontSize": 11,
            "color": "#CCCCCC"
        },
        {
            "type": "text",
            "textType": "DATETIME",
            "alignment": "END",
            "fontSize": 10,
            "color": "#888888",
            "format": "yyyy.MM.dd HH:mm"
        }
    ]
}